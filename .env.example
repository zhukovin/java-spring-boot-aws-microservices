# ── OrderFlow Environment Variables ───────────────────────────────────────────
# Copy this file to .env and populate values for local development.
# Production values are managed via AWS Secrets Manager / ECS task definition.

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=           # Not needed when running on ECS (uses task role)
AWS_SECRET_ACCESS_KEY=       # Not needed when running on ECS (uses task role)

# ── DynamoDB ──────────────────────────────────────────────────────────────────
# Leave blank to use AWS DynamoDB; set to http://localhost:8000 for local
DYNAMODB_ENDPOINT=

# Table names (defaults match the values in docker-compose.yml)
ORDERS_TABLE=orders
IDEMPOTENCY_TABLE=order_idempotency_keys
OUTBOX_TABLE=order_outbox
INVENTORY_TABLE=inventory
INVENTORY_IDEMPOTENCY_TABLE=inventory_idempotency

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Topic names
ORDERS_EVENTS_TOPIC=orders.events
INVENTORY_EVENTS_TOPIC=inventory.events
PAYMENT_EVENTS_TOPIC=payment.events

# ── Outbox Publisher ──────────────────────────────────────────────────────────
OUTBOX_POLL_INTERVAL_MS=1000
OUTBOX_BATCH_SIZE=50

# ── API Gateway ───────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# Upstream service URLs (used by api-gateway)
ORDER_SERVICE_URL=http://localhost:8081

# Comma-separated valid API keys.
# In production: populate from AWS Secrets Manager.
API_KEYS=dev-key-1,dev-key-2

# ── Observability ─────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
TRACING_SAMPLE_RATE=1.0
LOG_LEVEL=INFO
